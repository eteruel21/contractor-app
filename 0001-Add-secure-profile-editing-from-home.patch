+              <TextInput
+                autoCapitalize="words"
+                autoComplete="name"
+                maxLength={120}
+                onChangeText={setFullName}
+                placeholder="Tu nombre completo"
+                placeholderTextColor={colors.textMuted}
+                style={styles.input}
+                value={fullName}
+              />
+            </View>
+
+            <Text style={styles.label}>Teléfono</Text>
