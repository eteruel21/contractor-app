# Conexión administrativa únicamente para crear roles y la base de datos.
DATABASE_ADMIN_URL=postgresql://postgres:REEMPLAZAR@127.0.0.1:5432/postgres
DATABASE_NAME=contractor_pro

# Credenciales creadas por db:bootstrap.
CONTRACTOR_MIGRATOR_PASSWORD=REEMPLAZAR
CONTRACTOR_API_PASSWORD=REEMPLAZAR

# Conexión utilizada exclusivamente para migraciones y seeds.
MIGRATOR_DATABASE_URL=postgresql://contractor_migrator:REEMPLAZAR@127.0.0.1:5432/contractor_pro

# Confirmación obligatoria para registrar el baseline de una base existente.
BASELINE_CONFIRM_DATABASE=contractor_pro
