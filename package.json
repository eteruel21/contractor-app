{
  "name": "contractor-app",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:bootstrap": "node --env-file-if-exists=database/.env database/scripts/bootstrap.mjs",
    "db:baseline": "node --env-file-if-exists=database/.env database/scripts/baseline.mjs",
    "db:repair-checksums": "node --env-file-if-exists=database/.env database/scripts/baseline.mjs --repair-checksums",
    "db:migrate": "node --env-file-if-exists=database/.env database/scripts/migrate.mjs",
    "db:status": "node --env-file-if-exists=database/.env database/scripts/migrate.mjs --status",
    "db:seed": "node --env-file-if-exists=database/.env database/scripts/seed.mjs",
    "test:api": "npm run test -w apps/api",
    "test:database-tools": "node --test database/scripts/*.test.mjs",
    "test:invoice-db": "node --env-file-if-exists=database/.env database/scripts/invoice-payments.integration.mjs",
    "typecheck": "npm run typecheck -w apps/api && npm run typecheck -w apps/admin-web && npm run typecheck -w apps/mobile",
    "build:api": "npm run build -w apps/api",
    "build:admin": "npm run build -w apps/admin-web",
    "build:mobile": "npm run build:web -w apps/mobile",
    "deploy:admin": "npm run build:admin && npx wrangler pages deploy apps/admin-web/dist --project-name contractor-admin-web --branch main",
    "deploy:mobile": "npm run build:mobile && npx wrangler pages deploy apps/mobile/dist --project-name contractor-pro-web --branch main",
    "validate": "npm run typecheck && npm run build:api && npm run build:admin"
  },
  "devDependencies": {
    "pg": "^8.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-screens": "4.25.2",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-worklets": "0.10.0"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-screens": "4.25.2",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-worklets": "0.10.0"
  }
}
